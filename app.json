      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.svishev.andrey.vigotrade",
      "permissions": [
        "CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "2c2b8356-c70b-4444-817b-978a3f587941"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/2c2b8356-c70b-4444-817b-978a3f587941"
    }
  }
